# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-key

# AI APIs (at least one required)
QWEN_API_KEY=your-qwen-key
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.0-flash
COHERE_API_KEY=your-cohere-key

# Email
RESEND_API_KEY=your-resend-key
EMAIL_FROM=noreply@chat-analyzer.ru

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# YooKassa (payments)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
# Optional: override API base (rarely needed)
YOOKASSA_API_BASE_URL=https://api.yookassa.ru/v3
# Optional: simple webhook protection (send header `x-yookassa-webhook-token`)
YOOKASSA_WEBHOOK_TOKEN=your-webhook-token
